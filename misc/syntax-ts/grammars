# Shebang-based detection (for files without recognized extensions)
# Note: MC's regex engine does not support \b or \s.
# Spaces in patterns must be escaped as \x20 (the parser splits on whitespace).
shebang ^#!.*[/\x20](bash|sh)(\x20|$) bash Shell\ Script
shebang ^#!.*[/\x20]python python Python\ Program
shebang ^#!.*[/\x20]perl perl Perl\ Program
shebang ^#!.*[/\x20]ruby ruby Ruby\ Program
shebang ^#!.*[/\x20]lua lua Lua\ Program
shebang ^#!.*[/\x20]tclsh tcl Tcl\ Program
shebang ^#!.*[/\x20]node javascript JavaScript\ Program
shebang ^#!.*[/\x20]awk awk AWK\ Program
shebang ^#!.*[/\x20]php php PHP\ Program
