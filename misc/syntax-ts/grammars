file \.[ch]$ c C\ Program
file (Caddyfile|\.caddyfile)$ caddy Caddyfile
file \.(cob|cbl|cpy)$ cobol COBOL
file (CMakeLists\.txt|\.cmake)$ cmake CMake
file \.(cpp|cxx|cc|c\+\+|hpp|hxx|hh|h\+\+|ii?)$ cpp C++\ Program
file \.(cs)$ c_sharp C#\ Program
file \.(css)$ css CSS
file \.(cu|cuh)$ cuda CUDA
file \.(d|di)$ d D\ Program
file \.(diff|patch)$ diff Diff
file (Dockerfile|\.dockerfile)$ dockerfile Dockerfile
file \.(dot|gv)$ dot Graphviz\ DOT
file \.(erl|hrl)$ erlang Erlang\ Program
file \.(f90|f95|f03|f08|f|for|fpp|ftn)$ fortran Fortran\ Program
file \.(glsl|vert|frag|geom|tesc|tese|comp)$ glsl GLSL\ Shader
file \.(go)$ go Go\ Program
file \.(hs|lhs)$ haskell Haskell\ Program
file \.(tf|tfvars|hcl)$ hcl Terraform/HCL
file \.(html?|xhtml)$ html HTML
inject html javascript script_element/raw_text
inject html css style_element/raw_text
file \.(idl)$ idl IDL
file \.(ini|cfg|inf)$ ini INI\ File
file \.(java)$ java Java\ Program
file \.(js|mjs|cjs|jsx)$ javascript JavaScript\ Program
file \.(json|jsonc)$ json JSON
file \.(kt|kts)$ kotlin Kotlin\ Program
file \.(lisp|cl|lsp|el|asd)$ commonlisp Lisp
file \.(lua)$ lua Lua\ Program
file (Makefile|makefile|GNUmakefile|\.mk)$ make Makefile
file \.(md|markdown|mkd)$ markdown Markdown
inject markdown markdown_inline inline,pipe_table_cell
inject_dynamic markdown fenced_code_block info_string code_fence_content

